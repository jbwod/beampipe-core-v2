# Shaping profile for ~200-source discovery benchmarks.
BEAMPIPE_SCHEDULER_INTERVAL_SECONDS=30

BEAMPIPE_WORKER_CONCURRENCY=8
BEAMPIPE_WORKER_POLL_INTERVAL_MS=200
BEAMPIPE_WORKER_LOCK_SECONDS=600
# Keep CASDA load manageable: 8 batches × 3 TAP eh≈ 24 concurrent queries
BEAMPIPE_DISCOVERY_SOURCE_CONCURRENCY=3

BEAMPIPE_DB_MAX_CONNECTIONS=30

BEAMPIPE_SHAPING_DISCOVERY_MAX_IN_FLIGHT_BATCHES=8
BEAMPIPE_SHAPING_DISCOVERY_MAX_BATCHES_PER_TICK=50
BEAMPIPE_SHAPING_EXECUTION_MAX_IN_FLIGHT_RUNS=4
BEAMPIPE_SHAPING_QUEUE_MAX_DEPTH=2000
