
# Source before starting workers: set -a && source config/shaping.1000sources.env && set +a

BEAMPIPE_SCHEDULER_INTERVAL_SECONDS=30

BEAMPIPE_WORKER_CONCURRENCY=4
BEAMPIPE_WORKER_POLL_INTERVAL_MS=200
BEAMPIPE_WORKER_LOCK_SECONDS=600
BEAMPIPE_DISCOVERY_SOURCE_CONCURRENCY=5

BEAMPIPE_DB_MAX_CONNECTIONS=25

BEAMPIPE_SHAPING_DISCOVERY_MAX_IN_FLIGHT_BATCHES=24
BEAMPIPE_SHAPING_DISCOVERY_MAX_BATCHES_PER_TICK=100
BEAMPIPE_SHAPING_EXECUTION_MAX_IN_FLIGHT_RUNS=10
BEAMPIPE_SHAPING_QUEUE_MAX_DEPTH=5000
BEAMPIPE_SHAPING_ENQUEUE_PACING_MS=0
