# Local development defaults. Copy to .env; never commit .env.
BEAMPIPE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/beampipe
BEAMPIPE_JWT_SECRET=replace-with-at-least-32-random-characters
BEAMPIPE_CONFIG=beampipe.yaml

# Keep external work disabled until `beampipe doctor` passes.
BEAMPIPE_USE_REAL_BACKENDS=false
BEAMPIPE_CASDA_TAP_URL=https://casda.csiro.au/casda_vo_tools/tap/sync
BEAMPIPE_VIZIER_TAP_URL=https://tapvizier.cds.unistra.fr/TAPVizieR/tap/sync
BEAMPIPE_TM_URL=http://127.0.0.1:9000
BEAMPIPE_DIM_URL=http://127.0.0.1:8001

# Beampipe control-plane worker settings.
BEAMPIPE_WORKER_POOL=default
BEAMPIPE_WORKER_CONCURRENCY=4
BEAMPIPE_WORKER_SCHEDULER_ENABLED=false
BEAMPIPE_WORKER_LOCK_SECONDS=600

# Production credentials belong in mounted files or a secret manager.
CASDA_USERNAME=
CASDA_PASSWORD_FILE=
SLURM_SSH_PRIVATE_KEY_FILE=
SLURM_SSH_PRIVATE_KEY_PASSPHRASE_FILE=
SLURM_SSH_KNOWN_HOSTS_SOURCE=
BEAMPIPE_SLURM_SSH_STRICT_KNOWN_HOSTS=true

# Production Compose also requires these values.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=beampipe
