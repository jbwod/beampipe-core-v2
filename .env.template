# Beampipe v2 — copy to .env and fill in secrets (never commit .env).

# --- Core ---
BEAMPIPE_ENV=development
# production: BEAMPIPE_ENV=production and BEAMPIPE_SECURITY_STRICT=true (default strict in prod)
BEAMPIPE_JWT_SECRET=change-me-to-at-least-32-random-characters
DATABASE_URL=postgres://postgres:postgres@localhost:5432/beampipe
BEAMPIPE_CORS_ALLOW_ORIGINS=
BEAMPIPE_METRICS_PUBLIC=false
BEAMPIPE_REQUIRE_RATE_LIMITER=false

# --- Observability (production OTLP) ---
# Set per process role: beampipe-api, beampipe-scheduler, beampipe-worker
BEAMPIPE_OTEL_ENABLED=false
BEAMPIPE_OTEL_ENDPOINT=http://127.0.0.1:4317
BEAMPIPE_OTEL_SERVICE_NAME=beampipe-v2
BEAMPIPE_OTEL_SAMPLER_RATIO=1.0
BEAMPIPE_LOG_JSON=false
BEAMPIPE_PROCESS_ROLE=worker

# --- Real backends (Setonix / CASDA) ---
BEAMPIPE_USE_REAL_BACKENDS=false
CASDA_USERNAME=
# Prefer CASDA_PASSWORD_FILE in production. CASDA_PASSWORD is for local/dev env injection.
CASDA_PASSWORD=
CASDA_PASSWORD_FILE=
CASDA_LOGIN_URL=https://data.csiro.au/casda_vo_proxy/vo/tap/availability
BEAMPIPE_CASDA_TAP_URL=https://casda.csiro.au/casda_vo_tools/tap/sync

# --- Slurm SSH (precedence: PEM env → PATH → FILE → ~/.ssh with fallback flag) ---
# Prefer mounted files. Inline PEM is development-only and rejected in production unless BEAMPIPE_ALLOW_INLINE_SECRETS=true.
# Bare metal: key should be owned by the Beampipe service user, mode 0600 or 0400.
# Docker/Kubernetes/systemd credentials: root-owned mounted secret files are accepted when readable.
# SLURM_SSH_PRIVATE_KEY=<PEM contents for local/dev only>
SLURM_SSH_PRIVATE_KEY_PATH=
SLURM_SSH_PRIVATE_KEY_FILE=
SLURM_SSH_KNOWN_HOSTS=
SLURM_SSH_KNOWN_HOSTS_SOURCE=
SLURM_SSH_PRIVATE_KEY_PASSPHRASE=
SLURM_SSH_PRIVATE_KEY_PASSPHRASE_FILE=
# Aliases: passcode wording and legacy Python manual_ssh
SLURM_SSH_PRIVATE_KEY_PASSCODE=
SLURM_SSH_PRIVATE_KEY_PASSCODE_FILE=
# SSH_KEY_PASSPHRASE=
BEAMPIPE_SLURM_SSH_STRICT_KNOWN_HOSTS=
BEAMPIPE_ALLOW_INSECURE_SSH_HOST_KEYS=false
BEAMPIPE_SLURM_SSH_ALLOW_HOME_FALLBACK=false
BEAMPIPE_ALLOW_INLINE_SECRETS=false
SLURM_REMOTE_USER=

# Compose paths (see deploy/ssh/README.md)
# SLURM_SSH_PRIVATE_KEY_FILE=./deploy/ssh/id_slurm
# SLURM_SSH_KNOWN_HOSTS_SOURCE=./deploy/ssh/known_hosts
